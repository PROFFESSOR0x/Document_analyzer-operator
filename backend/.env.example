# Application Settings
APP_NAME=Document Analyzer Operator
APP_VERSION=0.1.0
APP_DEBUG=false
APP_ENVIRONMENT=production
APP_API_PREFIX=/api/v1

# Server Settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4
APP_RELOAD=false

# Database Settings (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=document_analyzer
DATABASE_URL=postgresql+asyncpg://postgres:your-secure-password-here@localhost:5432/document_analyzer
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
TOKEN_BLACKLIST_ENABLED=true

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://yourdomain.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Security Settings
BCRYPT_ROUNDS=12
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# API Key Encryption (Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Default LLM Provider Settings
DEFAULT_LLM_PROVIDER=openai

# OpenAI Settings
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# Anthropic Settings
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Ollama Settings (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# LM Studio Settings (Local)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model

# vLLM Settings (Local)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=facebook/opt-125m

# Custom Provider Settings
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_MODEL=

# File Storage Settings (MinIO/S3)
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=documents
STORAGE_USE_SSL=false
STORAGE_REGION=us-east-1

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/app.log
