# Document Analyzer Operator - Native Environment Configuration
# This file contains settings specific to native (non-Docker) deployment
# Copy this file to .env and update the values

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=Document Analyzer Operator
APP_VERSION=0.1.0
APP_DEBUG=true
APP_ENVIRONMENT=development
APP_API_PREFIX=/api/v1

# =============================================================================
# Server Settings
# =============================================================================
APP_HOST=127.0.0.1
APP_PORT=8000
APP_WORKERS=1
APP_RELOAD=true

# =============================================================================
# Database Settings (PostgreSQL)
# For native setup, ensure PostgreSQL is installed and running locally
# =============================================================================
POSTGRES_USER=document_analyzer
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=document_analyzer
DATABASE_URL=postgresql+asyncpg://document_analyzer:change_this_secure_password@localhost:5432/document_analyzer
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# =============================================================================
# Redis Settings
# For native setup, ensure Redis is installed and running locally
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# =============================================================================
# JWT Authentication
# Generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
TOKEN_BLACKLIST_ENABLED=true

# =============================================================================
# CORS Settings
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# =============================================================================
# Security Settings
# =============================================================================
BCRYPT_ROUNDS=12
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# API Key Encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =============================================================================
ENCRYPTION_KEY=

# =============================================================================
# Default LLM Provider Settings
# =============================================================================
DEFAULT_LLM_PROVIDER=openai

# =============================================================================
# OpenAI Settings
# Get your API key from: https://platform.openai.com/api-keys
# =============================================================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# =============================================================================
# Anthropic Settings
# Get your API key from: https://console.anthropic.com/settings/keys
# =============================================================================
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# =============================================================================
# Ollama Settings (Local LLM)
# Install Ollama: https://ollama.ai/
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# =============================================================================
# LM Studio Settings (Local LLM)
# Install LM Studio: https://lmstudio.ai/
# =============================================================================
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model

# =============================================================================
# vLLM Settings (Local LLM)
# Install vLLM: https://docs.vllm.ai/
# =============================================================================
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=facebook/opt-125m

# =============================================================================
# Custom Provider Settings
# =============================================================================
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_MODEL=

# =============================================================================
# File Storage Settings
# For native setup, you can use local filesystem or MinIO/S3
# =============================================================================
STORAGE_PROVIDER=local
STORAGE_ROOT=./storage
# For MinIO/S3:
# STORAGE_PROVIDER=minio
# STORAGE_ENDPOINT=localhost:9000
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_BUCKET=documents
# STORAGE_USE_SSL=false
# STORAGE_REGION=us-east-1

# =============================================================================
# Vector Database Settings (Qdrant)
# For native setup, install Qdrant locally or use cloud version
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================================
# Graph Database Settings (Neo4j)
# For native setup, install Neo4j locally or use Aura cloud
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_this_secure_password

# =============================================================================
# Workflow Engine Settings (Temporal)
# For native setup, install Temporal locally or use cloud version
# =============================================================================
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default

# =============================================================================
# Logging Settings
# =============================================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/app.log

# =============================================================================
# NATIVE SETUP SPECIFIC SETTINGS
# =============================================================================
# These settings are only used for native (non-Docker) deployment

# Process Management
NATIVE_MODE=true
USE_SYSTEMD=false  # Set to true for Linux production deployments

# Health Check Settings
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# File Upload Settings
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes
UPLOAD_DIR=./uploads

# Temporary Files
TEMP_DIR=./tmp
CLEANUP_TEMP_ON_START=true
